# Example environment variables for backup scripts
# Copy this to .env.local and fill in your actual values

# NAS connection details
NAS_USER=your_nas_username
NAS_HOST=192.168.1.11
NAS_BACKUP_PATH="/volume1/Backup/ChronoSync/Extreme GRN/"

# Backup paths
SOURCE_PATH="/Volumes/Extreme GRN/"
LOCAL_BACKUP_PATH="/Volumes/Extreme BLK/"

# Exclusions file (optional, defaults to ~/.exclusions.txt)
EXCLUSIONS_FILE="${HOME}/.exclusions.txt"